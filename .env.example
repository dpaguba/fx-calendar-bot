DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_application_id_here
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/forex-bot

# If set, slash commands are deployed instantly to this guild (for testing).
# Leave empty to deploy globally (can take up to 1 hour to propagate).
DEV_GUILD_ID=

# Set to "true" to run the morning job immediately on bot startup (for testing).
RUN_ON_START=false
